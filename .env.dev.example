# =====================================================================
# blockunits — ENTERPRISE (ee) local dev config
# DB + queue backed by Docker containers (blockunits_postgres / blockunits_redis).
# Original CE/PGLite config backed up at .env.dev.ce-backup — restore it to run CE.
# =====================================================================

IB_EDITION=ee
IB_ENVIRONMENT=dev
IB_LOG_LEVEL=debug
IB_LOG_PRETTY=true
IB_TELEMETRY_ENABLED=false

# --- Postgres (Docker: blockunits_postgres, host port 5433) ---
IB_DB_TYPE=POSTGRES
IB_POSTGRES_HOST=localhost
IB_POSTGRES_PORT=5433
IB_POSTGRES_DATABASE=blockunits
IB_POSTGRES_USERNAME=postgres
IB_POSTGRES_PASSWORD=CHANGE_ME

# --- Redis (Docker: blockunits_redis, host port 6380) ---
IB_QUEUE_MODE=REDIS
IB_REDIS_HOST=localhost
IB_REDIS_PORT=6380

# --- Secrets (REDIS mode does NOT auto-generate the encryption key, so it is set explicitly) ---
IB_JWT_SECRET=CHANGE_ME
IB_ENCRYPTION_KEY=CHANGE_ME

# --- App URLs / dev pieces ---
IB_API_KEY=CHANGE_ME
IB_CACHE_PATH="./dev/cache"
IB_CONFIG_PATH="./dev/config"
IB_FRONTEND_URL=http://localhost:4200
IB_WEBHOOK_URL=http://localhost:3000
IB_DEV_BLOCKS="google-bigquery,google-calendar,google-cloud-storage,google-contacts,google-docs,google-drive,google-forms,google-gemini,google-my-business,google-search,google-search-console,google-sheets,google-slides,google-tasks,google-vertexai,googlechat,slack,store"
IB_LOAD_TRANSLATIONS_FOR_DEV_BLOCKS=false
IB_EXECUTION_MODE=UNSANDBOXED

# --- Timeouts / triggers ---
IB_TRIGGER_DEFAULT_POLL_INTERVAL=5
IB_WEBHOOK_TIMEOUT_SECONDS=30
IB_FLOW_TIMEOUT_SECONDS=600

# --- Block / template / integration sources (empty = disabled, no outbound call) ---
IB_BLOCKS_SYNC_MODE=NONE
IB_BLOCKS_REGISTRY_URL=
IB_TEMPLATES_SOURCE_URL=
IB_CLOUDFLARE_API_TOKEN=
IB_CLOUDFLARE_ZONE_ID=
IB_CLOUDFLARE_API_BASE=
IB_CLOUDFLARE_SAAS_FALLBACK_ORIGIN=

# --- BullMQ queue UI (Redis mode) ---
IB_QUEUE_UI_ENABLED=true
IB_QUEUE_UI_USERNAME=admin
IB_QUEUE_UI_PASSWORD=CHANGE_ME

# --- Worker token (local dev only) ---
IB_WORKER_TOKEN=CHANGE_ME

# --- Platform email (ALL emails: invites, OTP, alerts, browser-agent notifications) ---
# Unconfigured in dev on purpose -> the log sender is used (emails are logged, not sent).
# To test real delivery, uncomment ONE transport below.
# Transport selection: REST | SMTP. Unset = auto (REST if configured, else SMTP).
# IB_EMAIL_TRANSPORT=REST
# REST transport (provider-agnostic; ZEPTOMAIL or GENERIC body):
# IB_EMAIL_REST_PROVIDER=ZEPTOMAIL
# IB_EMAIL_REST_URL=https://api.zeptomail.com/v1.1/email
# IB_EMAIL_REST_AUTH_HEADER=Authorization
# IB_EMAIL_REST_AUTH_VALUE=Zoho-enczapikey CHANGE_ME
# SMTP transport:
# IB_SMTP_HOST=
# IB_SMTP_PORT=587
# IB_SMTP_USERNAME=
# IB_SMTP_PASSWORD=
# Sender identity (both transports; defaults: "Intellisper" / noreply@kurvant.com):
# IB_SMTP_SENDER_EMAIL=
# IB_SMTP_SENDER_NAME=

# --- Browser agent (Intellisper) model keys ---
# REQUIRED for the browser agent to answer a single chat turn. Without a key every
# turn fails: the key resolver falls back to ENV mode (no managed OpenRouter key on
# a local platform) and the model provider then has nothing to build a model with.
#
# ANTHROPIC powers the default/escalation/reasoning/distill tiers (Haiku/Sonnet/Opus)
# and is what the agent uses for ordinary turns — set this one first.
# OPENAI powers only the cross-vendor fallback tier and memory embeddings; optional,
# but without it a fallback after an Anthropic outage, and memory recall, are unavailable.
IB_BROWSER_AGENT_ANTHROPIC_API_KEY=
IB_BROWSER_AGENT_OPENAI_API_KEY=

# Optional per-tier model overrides (defaults shown; leave unset to use them).
# IB_BROWSER_AGENT_DEFAULT_MODEL=claude-haiku-4-5
# IB_BROWSER_AGENT_ESCALATION_MODEL=claude-sonnet-4-6
# IB_BROWSER_AGENT_REASONING_MODEL=claude-opus-4-6
# IB_BROWSER_AGENT_FALLBACK_MODEL=gpt-4o
# IB_BROWSER_AGENT_DISTILL_MODEL=claude-haiku-4-5
# IB_BROWSER_AGENT_EMBEDDING_MODEL=text-embedding-3-small
