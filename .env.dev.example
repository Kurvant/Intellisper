# =====================================================================
# blockunits — ENTERPRISE (ee) local dev config
# DB + queue backed by Docker containers (blockunits_postgres / blockunits_redis).
# Original CE/PGLite config backed up at .env.dev.ce-backup — restore it to run CE.
# =====================================================================

IB_EDITION=ee
IB_ENVIRONMENT=dev
IB_LOG_LEVEL=debug
IB_LOG_PRETTY=true
IB_TELEMETRY_ENABLED=false

# --- Postgres (Docker: blockunits_postgres, host port 5433) ---
IB_DB_TYPE=POSTGRES
IB_POSTGRES_HOST=localhost
IB_POSTGRES_PORT=5433
IB_POSTGRES_DATABASE=blockunits
IB_POSTGRES_USERNAME=postgres
IB_POSTGRES_PASSWORD=CHANGE_ME

# --- Redis (Docker: blockunits_redis, host port 6380) ---
IB_QUEUE_MODE=REDIS
IB_REDIS_HOST=localhost
IB_REDIS_PORT=6380

# --- Secrets (REDIS mode does NOT auto-generate the encryption key, so it is set explicitly) ---
IB_JWT_SECRET=CHANGE_ME
IB_ENCRYPTION_KEY=CHANGE_ME

# --- App URLs / dev pieces ---
IB_API_KEY=CHANGE_ME
IB_CACHE_PATH="./dev/cache"
IB_CONFIG_PATH="./dev/config"
IB_FRONTEND_URL=http://localhost:4200
IB_WEBHOOK_URL=http://localhost:3000
IB_DEV_BLOCKS="google-bigquery,google-calendar,google-cloud-storage,google-contacts,google-docs,google-drive,google-forms,google-gemini,google-my-business,google-search,google-search-console,google-sheets,google-slides,google-tasks,google-vertexai,googlechat,slack,store"
IB_LOAD_TRANSLATIONS_FOR_DEV_BLOCKS=false
IB_EXECUTION_MODE=UNSANDBOXED

# --- Timeouts / triggers ---
IB_TRIGGER_DEFAULT_POLL_INTERVAL=5
IB_WEBHOOK_TIMEOUT_SECONDS=30
IB_FLOW_TIMEOUT_SECONDS=600

# --- Piece / template / integration sources (empty = disabled, no outbound call) ---
IB_PIECES_SYNC_MODE=NONE
IB_PIECES_REGISTRY_URL=
IB_TEMPLATES_SOURCE_URL=
IB_CLOUDFLARE_API_TOKEN=
IB_CLOUDFLARE_ZONE_ID=
IB_CLOUDFLARE_API_BASE=
IB_CLOUDFLARE_SAAS_FALLBACK_ORIGIN=

# --- BullMQ queue UI (Redis mode) ---
IB_QUEUE_UI_ENABLED=true
IB_QUEUE_UI_USERNAME=admin
IB_QUEUE_UI_PASSWORD=CHANGE_ME

# --- Worker token (local dev only) ---
IB_WORKER_TOKEN=CHANGE_ME
